#include <Adafruit_GFX.h>
#include <Adafruit_ST7735.h>
#include <SPI.h>
#include <ESP32Servo.h>

// ===== TFT =====
#define TFT_CS     15
#define TFT_RST    4
#define TFT_DC     2

// ===== PINY =====
const int trigPin   = 5;
const int echoPin   = 13;
const int servoPin  = 12;        // ← zmienione na 12

// Obiekty
Adafruit_ST7735 tft = Adafruit_ST7735(TFT_CS, TFT_DC, TFT_RST);
Servo myServo;

void setup() {
  Serial.begin(115200);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  // === NAPRAWA SERVO NA ESP32 ===
  ESP32PWM::allocateTimer(0);
  ESP32PWM::allocateTimer(1);
  ESP32PWM::allocateTimer(2);
  
  myServo.setPeriodHertz(50);
  myServo.attach(servoPin, 500, 2400);   // min 500µs, max 2400µs

  // TFT
  tft.initR(INITR_BLACKTAB);
  tft.setRotation(1);
  tft.fillScreen(ST77XX_BLACK);

  tft.setTextColor(ST77XX_GREEN);
  tft.setTextSize(2);
  tft.setCursor(25, 25);
  tft.println("RADAR");
  
  delay(1500);
  Serial.println("Radar start - Servo na pin 12");
}

int getDistance() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(4);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 25000);
  int distance = duration * 0.0343 / 2;

  if (distance <= 0 || distance > 40) return 40;
  return distance;
}

void drawRadar(int angle, int distance) {
  tft.fillRect(0, 20, 160, 110, ST77XX_BLACK);

  tft.drawCircle(80, 118, 85, ST77XX_GREEN);
  tft.drawCircle(80, 118, 55, ST77XX_GREEN);
  tft.drawCircle(80, 118, 25, ST77XX_GREEN);

  float rad = radians(angle);
  int x = 80 + cos(rad) * 85;
  int y = 118 - sin(rad) * 85;
  tft.drawLine(80, 118, x, y, ST77XX_GREEN);

  if (distance < 40) {
    int ox = 80 + cos(rad) * (distance * 2.125);
    int oy = 118 - sin(rad) * (distance * 2.125);
    tft.fillCircle(ox, oy, 5, ST77XX_RED);
  }

  tft.fillRect(0, 0, 160, 19, ST77XX_BLACK);
  tft.setCursor(4, 5);
  tft.setTextSize(1);
  tft.print("KAT:");
  tft.print(angle);
  tft.print("  D:");
  tft.print(distance);
  tft.print("cm");
}

void loop() {
  static int angle = 20;
  static bool forward = true;

  myServo.write(angle);        // ruch serwa
  
  int distance = getDistance();
  drawRadar(angle, distance);

  if (forward) angle += 3;
  else         angle -= 3;

  if (angle >= 160) forward = false;
  if (angle <= 20)  forward = true;

  delay(35);
}
